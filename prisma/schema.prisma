generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS --------------------------

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  PAST
}

enum UserRole {
  ADMIN
  SUPER_USER
}

// MODELS -------------------------------------

model User {
  id               String    @id @default(cuid())
  role             UserRole  @default(ADMIN)
  isSoundEffectsOn Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  email            String    @unique @db.VarChar(255)
  firstName        String?   @db.VarChar(255)
  lastName         String?   @db.VarChar(255)
  emailVerified    DateTime?
  stripeCustomerId String?
  phone            String?
  accounts         Account[]
  sessions         Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model News {
  id            String   @id @default(cuid())
  title         String
  excerpt       String   @default("")
  body          String   @default("")
  imageUrl      String   @default("")
  imageFilename String   @default("")
  externalLink  String?  @default("")
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VolunteerSubmission {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String
  mailingList  Boolean  @default(false)
  yardSign     Boolean  @default(false)
  doorKnocking Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  content   Json
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  createdAt DateTime @default(now())
  metadata  Json?
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  value       Boolean  @default(false)
  type        String   @default("boolean")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
